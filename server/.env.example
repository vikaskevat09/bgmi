# ===== Cashfree credentials =====
# Get these from Cashfree Dashboard → Developers → API Keys.
# Use TEST keys with CASHFREE_ENV=sandbox while building; production keys live.
CASHFREE_ENV=production
CASHFREE_APP_ID=your_app_id_here
CASHFREE_SECRET_KEY=your_secret_key_here
CASHFREE_API_VERSION=2023-08-01

# Where Cashfree sends the user back after payment, and where it posts webhooks.
# In a split deploy these point at your HOSTINGER (frontend) domain and the
# RENDER (backend) domain respectively. Must be HTTPS in production.
RETURN_URL=https://yourdomain.com/return.html
NOTIFY_URL=https://your-backend.onrender.com/api/webhook

PORT=8080

# Allowed browser origin(s) for CORS — the Hostinger domain(s) that call this API.
# Comma-separate multiple. Do NOT use * in production (cookies need a real origin).
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Login cookies are cross-site in a split deploy (frontend + backend on different
# domains), so they must be SameSite=None; Secure. Set this to true on Render.
COOKIE_CROSS_SITE=true

# Secret that signs login/admin session cookies. Use a long random string.
SESSION_SECRET=change-this-to-a-long-random-string

# ===== Admin panel =====
ADMIN_PASSWORD=change-this-strong-password

# ===== ID verification (RapidAPI) =====
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=
RAPIDAPI_URL_TEMPLATE=
RAPIDAPI_DEFAULT_REGION=ind
